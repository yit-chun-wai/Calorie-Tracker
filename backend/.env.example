# Local dev — plain Postgres
# DATABASE_URL=postgresql://postgres:password@localhost:5432/calorie_tracker

# Supabase (use the "Session mode" pooler URL from Project Settings > Database > Connection Pooling)
# Port 5432 = session mode (recommended), port 6543 = transaction mode
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

JWT_SECRET=change-me-to-a-long-random-string-in-production
OPENROUTER_API_KEY=sk-or-v1-...
FRONTEND_URL=http://localhost:5173
PORT=3001
NODE_ENV=development
